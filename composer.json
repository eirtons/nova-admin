{
    "name": "nbutl/nova-admin",
    "description": "多站点复用的通用后台底座：广告、站点设置、ads.txt、robots.txt、后台中文、登录与默认管理员（Laravel 12 + Filament 5）。",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "filament/filament": "^5.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Nbutl\\NovaAdmin\\": "src/",
            "Nbutl\\NovaAdmin\\Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nbutl\\NovaAdmin\\NovaAdminServiceProvider"
            ],
            "aliases": {
                "SiteConfig": "Nbutl\\NovaAdmin\\Facades\\SiteConfig",
                "Sitemap": "Nbutl\\NovaAdmin\\Facades\\Sitemap"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
